{
  "expo": {
    "name": "Handkraft",
    "slug": "handkraft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "handkraft",
    "newArchEnabled": false,
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/app-icon-android-foreground.png",
        "monochromeImage": "./assets/images/app-icon-android-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "package": "com.handkraft"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/handkraft_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e83cdb7-4245-419d-a461-871b88691f95"
      }
    }
  }
}
