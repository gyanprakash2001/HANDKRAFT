# Server
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/handkraft
JWT_SECRET=replace-with-a-strong-secret

# Optional absolute base URL used by selected debug routes.
PUBLIC_BASE_URL=http://localhost:5000

# CORS settings
# Leave empty in local dev if you want to allow all origins.
# In production, set exact frontend origins as comma-separated values.
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# Google OAuth audience(s)
# Recommended: set your Web Client ID here.
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Optional additional audiences accepted by /api/auth/google
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your-expo-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Razorpay (test/sandbox)
# Set RAZORPAY_ENABLED=true after adding test keys.
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_BRAND_NAME=HANDKRAFT
RAZORPAY_DESCRIPTION_PREFIX=HANDKRAFT Order

# NimbusPost integration
# Keep disabled until KYC, wallet, and warehouse setup are completed in NimbusPost.
NIMBUSPOST_ENABLED=false

# Modes:
# - auto: use V1 API key if present, otherwise use V2 email/password login
# - v1: force old API-key flow (ship.nimbuspost.com/api)
# - v2: force new bearer-token flow (api.nimbuspost.com/v1)
NIMBUSPOST_MODE=auto

# V1 (API key mode)
NIMBUSPOST_API_KEY=
NIMBUSPOST_WAREHOUSE_ID=
NIMBUSPOST_RTO_WAREHOUSE_ID=

# V2 (token mode)
NIMBUSPOST_API_EMAIL=
NIMBUSPOST_API_PASSWORD=
NIMBUSPOST_PICKUP_WAREHOUSE_NAME=
NIMBUSPOST_PICKUP_NAME=
NIMBUSPOST_PICKUP_ADDRESS_1=
NIMBUSPOST_PICKUP_ADDRESS_2=
NIMBUSPOST_PICKUP_CITY=
NIMBUSPOST_PICKUP_STATE=
NIMBUSPOST_PICKUP_PINCODE=
NIMBUSPOST_PICKUP_PHONE=

# Shared options
NIMBUSPOST_DEFAULT_COURIER_ID=autoship
NIMBUSPOST_REQUEST_AUTO_PICKUP=true
NIMBUSPOST_IS_INSURANCE=false
NIMBUSPOST_TAGS=handkraft
NIMBUSPOST_PACKAGE_WEIGHT_GRAMS=500
NIMBUSPOST_WEIGHT_PER_ITEM_GRAMS=0
NIMBUSPOST_PACKAGE_LENGTH_CM=10
NIMBUSPOST_PACKAGE_BREADTH_CM=10
NIMBUSPOST_PACKAGE_HEIGHT_CM=10
NIMBUSPOST_TIMEOUT_MS=25000
NIMBUSPOST_WEBHOOK_SECRET=

# Override only if NimbusPost changes API hosts.
NIMBUSPOST_V1_BASE_URL=https://ship.nimbuspost.com/api
NIMBUSPOST_V2_BASE_URL=https://api.nimbuspost.com/v1

# Seller payout wallet policy
# Money is released to seller wallet after delivery + hold days, then sellers claim manually.
PAYOUTS_ENABLED=true
PAYOUTS_HOLD_DAYS_AFTER_DELIVERY=1
PAYOUTS_DEFAULT_RESERVE_PERCENT=10
PAYOUTS_DEFAULT_MIN_PAYOUT_AMOUNT=0

# Scheduler releases on-hold payouts to claimable wallet state.
PAYOUTS_SCHEDULER_ENABLED=true
PAYOUTS_SCHEDULER_INTERVAL_MS=60000
PAYOUTS_SCHEDULER_BATCH_LIMIT=50
