# Server
PORT=5000
MONGO_URI=mongodb://localhost:27017/handkraft
JWT_SECRET=replace-with-a-strong-secret

# Google OAuth audience(s)
# Recommended: set your Web Client ID here.
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Optional additional audiences accepted by /api/auth/google
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your-expo-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Shiprocket integration
# Keep disabled until credentials are added and tested.
SHIPROCKET_ENABLED=false
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# Optional: used to verify incoming Shiprocket webhooks in later steps.
SHIPROCKET_WEBHOOK_SECRET=

# Optional: refresh auth token this many ms before expiry.
SHIPROCKET_TOKEN_REFRESH_BUFFER_MS=300000
